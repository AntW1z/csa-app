rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isModerator() {
      return request.auth != null && (role() == 'moderator' || role() == 'admin');
    }

    function isAdmin() {
      return request.auth != null && role() == 'admin';
    }

    // Anyone signed in can read profiles (needed to show pending requests
    // to moderators). Users can create their own doc on first sign-in and
    // edit their own fields, but cannot change their own role — only a
    // moderator/admin write can do that.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        (request.auth.uid == uid && request.resource.data.role == resource.data.role) ||
        isModerator()
      );
    }

    // Posts are public to read (no login needed to browse), but only
    // moderators/admins can write. The `featured` flag on a post is what
    // makes it the full-screen launch popup on Home — same rule covers it.
    match /posts/{postId} {
      allow read: if true;
      allow write: if isModerator();
    }

    // Home screen's auto-advancing image carousel — public to read, same
    // as posts, only moderators/admins curate it.
    match /carouselItems/{itemId} {
      allow read: if true;
      allow write: if isModerator();
    }

    // Drafted/sent push notifications, managed from Manage > Notifications.
    // Same trust level as posts/carouselItems — any moderator can draft,
    // edit, or send one.
    match /notifications/{notifId} {
      allow read: if isModerator();
      allow write: if isModerator();
    }

    // Moderation audit log. Moderators' actions still get logged (they can
    // create entries), but only an admin can read or clear the log itself —
    // moderators can't browse each other's history.
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isModerator();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
